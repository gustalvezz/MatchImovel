{
  "project_name": "Match Imob",
  "design_philosophy": {
    "identity": "E1 - The Anti-AI Designer",
    "core_principles": [
      "Fusion over Imitation: Mix Proptech precision with Lifestyle warmth.",
      "Emotion First: Buying a home is emotional; selling is analytical. Design for both.",
      "Content is King: The 'Match' is the hero.",
      "Negative Space: Luxury = Space."
    ],
    "anti_patterns": [
      "No generic 'Real Estate Blue' (#007bff).",
      "No standard Bootstrap columns.",
      "No 'Inter' for headings.",
      "No full-screen gradients without texture."
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Outfit, sans-serif",
      "body": "Inter, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-5xl md:text-7xl font-bold tracking-tight leading-[1.1]",
      "h2": "text-4xl md:text-5xl font-semibold tracking-tight",
      "h3": "text-2xl md:text-3xl font-medium",
      "body_lg": "text-lg md:text-xl leading-relaxed text-muted-foreground",
      "body_base": "text-base leading-relaxed text-foreground/80",
      "caption": "text-xs uppercase tracking-widest font-semibold text-muted-foreground"
    },
    "installation_commands": [
      "yarn add @fontsource/outfit @fontsource/inter @fontsource/jetbrains-mono"
    ]
  },
  "colors": {
    "palette": {
      "primary": {
        "DEFAULT": "hsl(246, 80%, 60%)", 
        "foreground": "hsl(0, 0%, 100%)",
        "description": "Electric Indigo - Tech & Future"
      },
      "secondary": {
        "DEFAULT": "hsl(150, 60%, 50%)",
        "foreground": "hsl(0, 0%, 100%)",
        "description": "Mint Green - Growth & Match"
      },
      "accent": {
        "DEFAULT": "hsl(280, 70%, 60%)",
        "foreground": "hsl(0, 0%, 100%)",
        "description": "Soft Purple - Creative/Magic"
      },
      "background": {
        "light": "hsl(0, 0%, 98%)",
        "dark": "hsl(222, 47%, 11%)"
      },
      "surface": {
        "glass": "bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border border-white/20 shadow-xl",
        "card": "bg-card text-card-foreground border border-border/50 shadow-sm hover:shadow-md transition-all duration-300"
      }
    },
    "gradients": {
      "hero_mesh": "bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-indigo-200 via-purple-100 to-transparent dark:from-indigo-900/40 dark:via-purple-900/20",
      "button_primary": "bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white shadow-lg shadow-indigo-500/25"
    }
  },
  "layout_strategies": {
    "spacing": {
      "container_padding": "p-6 md:p-12 lg:p-24",
      "section_gap": "gap-12 md:gap-24",
      "component_gap": "gap-4 md:gap-8"
    },
    "grids": {
      "bento_marketing": "grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 auto-rows-[minmax(180px,auto)] gap-4 md:gap-6",
      "dashboard_dense": "grid grid-cols-1 md:grid-cols-12 gap-4"
    },
    "containers": {
      "max_width": "max-w-7xl mx-auto w-full"
    }
  },
  "components": {
    "buttons": {
      "primary": "rounded-full h-12 px-8 font-medium transition-transform active:scale-95",
      "secondary": "rounded-full h-12 px-8 bg-secondary/10 text-secondary-foreground hover:bg-secondary/20",
      "outline": "rounded-full h-12 px-8 border-2 border-primary/20 hover:border-primary/50 bg-transparent"
    },
    "cards": {
      "glass": "rounded-2xl bg-white/40 dark:bg-black/40 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-xl",
      "feature": "group relative overflow-hidden rounded-3xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-8 hover:border-primary/50 transition-colors"
    },
    "inputs": {
      "style": "h-12 rounded-xl bg-slate-50 dark:bg-slate-900/50 border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
    }
  },
  "visual_assets": {
    "icons": {
      "library": "lucide-react",
      "style": "stroke-[1.5px] w-5 h-5"
    },
    "images": {
      "hero_buyer": {
        "url": "https://images.unsplash.com/photo-1758523419991-c6d6dae06626?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1NTJ8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBoYXBweSUyMGNvdXBsZSUyMGhvbWUlMjBrZXlzfGVufDB8fHx8MTc3Mjc3NjA1OHww&ixlib=rb-4.1.0&q=85",
        "alt": "Happy couple in modern kitchen",
        "category": "Marketing"
      },
      "hero_house": {
        "url": "https://images.unsplash.com/photo-1766603636562-531bb3e1dda8?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NzR8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBtaW5pbWFsaXN0JTIwaG91c2UlMjBleHRlcmlvciUyMGFyY2hpdGVjdHVyZXxlbnwwfHx8fDE3NzI3NzYwNTl8MA&ixlib=rb-4.1.0&q=85",
        "alt": "Modern minimalist house exterior",
        "category": "Marketing"
      },
      "agent_action": {
        "url": "https://images.unsplash.com/photo-1649151139875-ae8ea07082e2?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1NTN8MHwxfHNlYXJjaHwyfHxwcm9mZXNzaW9uYWwlMjByZWFsJTIwZXN0YXRlJTIwYWdlbnQlMjB0YWJsZXR8ZW58MHx8fHwxNzcyNzc2MDU5fDA&ixlib=rb-4.1.0&q=85",
        "alt": "Agent working on tablet",
        "category": "Dashboard"
      }
    }
  },
  "motion": {
    "libraries": [
      "framer-motion",
      "lenis"
    ],
    "patterns": {
      "page_transition": {
        "initial": { "opacity": 0, "y": 20 },
        "animate": { "opacity": 1, "y": 0 },
        "exit": { "opacity": 0, "y": -20 },
        "transition": { "duration": 0.4, "ease": "easeOut" }
      },
      "stagger_children": {
        "variants": {
          "hidden": { "opacity": 0 },
          "show": {
            "opacity": 1,
            "transition": {
              "staggerChildren": 0.1
            }
          }
        }
      },
      "hover_lift": "hover:-translate-y-1 transition-transform duration-300 ease-out"
    }
  },
  "universal_guidelines": [
    "Do NOT use gradients for text unless it's a very large heading.",
    "Do NOT use 'Inter' for headings. Use 'Outfit'.",
    "Always add 'data-testid' to interactive elements.",
    "Use 'sonner' for toasts.",
    "Use 'lucide-react' for icons.",
    "Ensure 60/40 split logic is clear in dashboard: 60% agent / 40% platform."
  ],
  "accessibility": {
    "contrast": "Ensure text contrast ratio of 4.5:1 for normal text.",
    "focus_states": "Visible focus rings on all interactive elements (ring-2 ring-primary/50).",
    "prefers_reduced_motion": "Respect user motion preferences."
  }
}